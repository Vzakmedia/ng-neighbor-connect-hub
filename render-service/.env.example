# Server Configuration
NODE_ENV=production
PORT=3000

# CORS - Comma-separated list of allowed origins
ALLOWED_ORIGINS=https://neighborlink.ng,https://neighborlink.ng

VITE_SUPABASE_PROJECT_ID="your-supabase-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="your-supabase-anon-key"
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_CLOUDINARY_CLOUD_NAME="your-cloudinary-cloud-name"
VITE_RENDER_API_URL="http://localhost:3000"
VITE_GOOGLE_MAPS_MAP_ID="your-google-maps-map-id"
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="your-twilio-auth-token"
TWILIO_PHONE_NUMBER="+1xxxxxxxxxx"
LIVEKIT_URL=wss://your-livekit-instance.livekit.cloud
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret

# Cloudinary Secrets (Backend Use)
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Optional: Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Upstash Redis (Optional - for production rate limiting)
# Get these from your Upstash console: https://console.upstash.com/
UPSTASH_REDIS_REST_URL=https://your-database.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token
